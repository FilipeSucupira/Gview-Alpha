generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("PLAYER")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  wishlist     Wishlist[]
  reviews      Review[]
  gameJams     GameJam[]
  jamEntries   GameJamEntry[]
  collections  Collection[]
}

model Game {
  id               String     @id @default(uuid())
  title            String
  slug             String     @unique
  shortDescription String
  fullDescription  String?
  coverUrl         String?
  trailerUrl       String?
  demoUrl          String?
  status           String     @default("AVAILABLE")
  genre            String?
  studioName       String?
  launchWindow     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  wishlist         Wishlist[]
  reviews          Review[]
  jamEntries       GameJamEntry[]
  collectionItems  CollectionItem[]
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([userId, gameId])
}

model Submission {
  id                    String    @id @default(uuid())
  gameTitle             String
  projectUrl            String?
  description           String
  launchPlans           String?
  targetPlatforms       String?
  launchDateRange       String?
  demoLink              String?
  nextFestParticipation Boolean   @default(false)
  heardAbout            String?
  additionalInfo        String?
  contactRole           String?
  contactEmail          String
  studioName            String?
  attachmentUrl         String?
  reviewStatus          String    @default("PENDING")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model GameJam {
  id          String        @id @default(uuid())
  title       String
  description String
  theme       String?
  startDate   DateTime
  endDate     DateTime
  status      String        @default("UPCOMING")
  creatorId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  creator     User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  entries     GameJamEntry[]
}

model GameJamEntry {
  id           String   @id @default(uuid())
  jamId        String
  gameId       String
  developerId  String
  createdAt    DateTime @default(now())
  jam          GameJam  @relation(fields: [jamId], references: [id], onDelete: Cascade)
  game         Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  developer    User     @relation(fields: [developerId], references: [id], onDelete: Cascade)
  @@unique([jamId, gameId])
}

model Collection {
  id          String           @id @default(uuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  gameId       String
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([collectionId, gameId])
}
