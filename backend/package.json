{
  "name": "gview-backend",
  "version": "2.0.0",
  "description": "Gview API — backend Express (arquitetura MVC) para plataforma de demos de jogos",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "supertest": "^6.3.4",
    "vitest": "^1.0.0"
  }
}