# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# URL do banco de dados SQLite (gerado pelo Prisma)
DATABASE_URL="file:./dev.db"

# Porta do servidor Express
PORT=3001

# Segredo para assinar os tokens JWT — use uma string longa e aleatória em produção
JWT_SECRET=seu-jwt-secret-aqui

# Chave da API RAWG (https://rawg.io/apidocs)
# Crie uma conta gratuita em rawg.io e gere sua chave
RAWG_API_KEY=sua-rawg-api-key-aqui

# Origens permitidas pelo CORS (separadas por vírgula)
# Desenvolvimento: http://localhost:5173
# Produção: https://seudominio.com
CORS_ORIGIN=http://localhost:5173